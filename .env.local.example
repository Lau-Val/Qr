# Supabase project URL (public, safe for the browser when used with anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Optional: anon key for future client-side Supabase usage (RLS-protected reads/writes)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: never expose in client bundles — bypasses RLS; use only in Server Components / Route Handlers
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp (Meta) — zie ook root .env.example
# NEXT_PUBLIC_META_APP_ID=
# NEXT_PUBLIC_META_EMBEDDED_SIGNUP_CONFIG_ID=
# META_APP_SECRET=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# WHATSAPP_TOKEN_ENCRYPTION_KEY=
