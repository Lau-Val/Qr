# Publieke keys (browser + SSR sessies)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Server-only dashboard (service role — nooit NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Bootstrap platform-beheer (komma-gescheiden e-mails) — altijd toegang tot /admin
# Extra beheerders: via Beheerdersaccount op /admin (tabel platform_admins) of handmatig in Supabase
SUPER_ADMIN_EMAILS=jij@voorbeeld.nl

# Optioneel: fallback slug als er geen sessie is (ontwikkeling)
NEXT_PUBLIC_BAR_SLUG=cafe-nova
NEXT_PUBLIC_DEFAULT_BAR_SLUG=cafe-nova

# Meta / WhatsApp (Embedded Signup + Cloud API webhooks) — server secrets nooit NEXT_PUBLIC_
# NEXT_PUBLIC_META_APP_ID=1234567890
# NEXT_PUBLIC_META_EMBEDDED_SIGNUP_CONFIG_ID=from_meta_developer_console
# META_APP_SECRET=app_secret_for_webhook_signature_verification
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=random_long_string_for_get_verification
# WHATSAPP_CLOUD_API_VERSION=v21.0
# 32-byte key, base64 — encrypts stored OAuth tokens at rest (openssl rand -base64 32)
# WHATSAPP_TOKEN_ENCRYPTION_KEY=
